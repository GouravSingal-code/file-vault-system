# Copy this file to .env and fill in the values
# NEVER commit .env to version control

DJANGO_ENVIRONMENT=development

# Django — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-random-secret-key

# PostgreSQL
DB_HOST=postgres
DB_NAME=file_vault_dev
DB_USER=postgres
DB_PASSWORD=replace-with-strong-password
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_FILE_UPLOAD_TOPIC=file-uploads
KAFKA_CONSUMER_GROUP_ID=file-vault-consumers

# Storage limits
USER_STORAGE_QUOTA_MB=100
MAX_FILE_SIZE_MB=5

# Logging
LOG_LEVEL=INFO

# Production only
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True
# SENTRY_DSN=https://...@sentry.io/...
